generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SuperAdmin
  Admin
  Teacher
  Student
  PublicViewer
}

enum UserStatus {
  Pending
  Active
  Suspended
  Expired
}

enum SubscriptionStatus {
  Pending
  Active
  Suspended
  Expired
}

enum BehaviorCategory {
  Positive
  Negative
}

enum PointLogSource {
  Teacher
  Admin
  System
}

enum PetStage {
  Egg
  Baby
  Growth
  Evolution
  Rare
}

enum InteractionType {
  Pat
  Feed
  Greet
  Encourage
}

enum AuditAction {
  Register
  Login
  Logout
  OpenTeacher
  SuspendTeacher
  RenewTeacher
  ResetPassword
  CreateClass
  CreateStudent
  PointChange
  PetInteraction
  SystemSettingUpdate
}

model User {
  id             String       @id @default(cuid())
  phone          String       @unique
  passwordHash   String
  name           String
  role           UserRole     @default(Teacher)
  status         UserStatus   @default(Pending)
  lastLoginAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  subscription   Subscription?
  classes        Class[]      @relation("TeacherClasses")
  behaviorRules  BehaviorRule[]
  pointLogs      PointLog[]   @relation("PointOperator")
  auditLogs      AuditLog[]   @relation("AuditActor")
  settings       SystemSetting[] @relation("SettingUpdater")

  @@index([role, status])
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String             @unique
  status      SubscriptionStatus @default(Pending)
  startsAt    DateTime?
  expiresAt   DateTime?
  note        String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
}

model Class {
  id            String          @id @default(cuid())
  teacherId     String
  name          String
  code          String          @unique
  description   String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  teacher       User            @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  students      Student[]
  behaviorRules BehaviorRule[]
  pointLogs     PointLog[]

  @@index([teacherId, isActive])
}

model Student {
  id              String            @id @default(cuid())
  classId         String
  name            String
  nickname        String?
  seatNo          String?
  code            String            @unique
  totalPoints     Int               @default(0)
  todayPoints     Int               @default(0)
  level           Int               @default(1)
  experience      Int               @default(0)
  mood            Int               @default(60)
  petName         String            @default("小宠物蛋")
  petStage        PetStage          @default(Egg)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  class           Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  pointLogs       PointLog[]
  evolutions      PetEvolution[]
  interactions    PetInteraction[]

  @@index([classId, totalPoints])
}

model BehaviorRule {
  id          String           @id @default(cuid())
  teacherId   String
  classId     String?
  name        String
  points      Int
  category    BehaviorCategory
  icon        String           @default("star")
  color       String           @default("#16a34a")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  teacher     User             @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class       Class?           @relation(fields: [classId], references: [id], onDelete: Cascade)
  pointLogs   PointLog[]

  @@index([teacherId, classId, isActive])
}

model PointLog {
  id           String          @id @default(cuid())
  studentId    String
  classId      String
  ruleId       String?
  operatorId   String?
  source       PointLogSource  @default(Teacher)
  points       Int
  reason       String
  remark       String?
  moodDelta    Int             @default(0)
  revertedAt   DateTime?
  createdAt    DateTime        @default(now())

  student      Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class        Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  rule         BehaviorRule?   @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  operator     User?           @relation("PointOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([studentId, createdAt])
  @@index([classId, createdAt])
}

model PetEvolution {
  id          String     @id @default(cuid())
  studentId   String
  fromStage   PetStage
  toStage     PetStage
  fromLevel   Int
  toLevel     Int
  petName     String
  fromPetName String?
  note        String?
  createdAt   DateTime   @default(now())

  student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

model PetInteraction {
  id          String          @id @default(cuid())
  studentId   String
  type        InteractionType
  moodDelta   Int             @default(1)
  message     String?
  createdAt   DateTime        @default(now())

  student     Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

model AuditLog {
  id          String      @id @default(cuid())
  actorId     String?
  action      AuditAction
  targetType  String
  targetId    String?
  detail      Json?
  ip          String?
  createdAt   DateTime    @default(now())

  actor       User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model SystemSetting {
  id          String    @id @default(cuid())
  key         String    @unique
  value       Json
  description String?
  updatedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  updatedBy   User?     @relation("SettingUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
}
